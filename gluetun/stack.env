GLUETUN_VERSION=${GLUETUN_VERSION:-latest}

VPN_SERVICE_PROVIDER=private internet access
VPN_TYPE=openvpn

OPENVPN_USER=${PIA_USER}
OPENVPN_PASSWORD=${PIA_PASSWORD}

# Comma-separated, tried left to right — change anytime via control API or redeploy
SERVER_REGIONS=${GLUETUN_SERVER_REGIONS:-Singapore,Japan}

# HTTP proxy (port 11157)
HTTPPROXY=on
HTTPPROXY_LOG=off

# SOCKS5 proxy (port 11158)
SHADOWSOCKS=on

# Control API (port 11159) — allows live region switching
HTTP_CONTROL_SERVER_ADDRESS=:8000
HTTP_CONTROL_SERVER_LOG=off

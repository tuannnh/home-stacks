COPYTELE_UPLOAD_URL=${COPYTELE_UPLOAD_URL:-http://localhost:8080/upload}
COPYTELE_PW=${COPYTELE_PW:-www}
OVERWRITE=false
DOWNLOAD_DIR=/tmp/music_downloader
# Cookies OFF: impersonation handles TikTok access, and a logged-in session
# makes TikTok serve audio-less HEVC. Only set this for genuinely private videos.
COOKIES_FILE=
MAX_JOBS=200
HOST=0.0.0.0
PORT=8080

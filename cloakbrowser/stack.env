MANAGER_VERSION=${MANAGER_VERSION:-latest}
CLOAKBROWSER_VERSION=${CLOAKBROWSER_VERSION:-latest}

# Manager auth — when set, UI and API require Authorization: Bearer <token>
AUTH_TOKEN=${AUTH_TOKEN}

# CloakBrowser binary options
CLOAKBROWSER_AUTO_UPDATE=${CLOAKBROWSER_AUTO_UPDATE:-true}
CLOAKBROWSER_CACHE_DIR=/root/.cloakbrowser

# --- required: Telegram credentials (from https://my.telegram.org) ---
TGFS_API_ID=${TGFS_API_ID:-"your_api_id_here"}
TGFS_API_HASH=${TGFS_API_HASH:-"your_api_hash_here"}
# dedicated PRIVATE channel id that stores the blobs (use `... channels`)
TGFS_CHANNEL=${TGFS_CHANNEL:-"-1001234567890"}
# --- optional tuning ---
TGFS_CHUNK_SIZE=${TGFS_CHUNK_SIZE:-"32MiB"}
TGFS_CACHE_CAP=${TGFS_CACHE_CAP:-"5GiB"}